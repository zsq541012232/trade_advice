# LLM 提供商（aihubmix / nim）
LLM_PROVIDER=aihubmix

# AIHUBMIX 配置
AIHUBMIX_API_KEY=your_api_key
AIHUBMIX_BASE_URL=https://api.aihubmix.com/v1
AIHUBMIX_MODEL=gpt-4o-mini

# NVIDIA NIM 配置
NVIDIA_NIM_API_KEY=your_nim_api_key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# 股票代码，多个用逗号分隔（可选；如配置 EMAIL_STOCK_ROUTER 可不填）
STOCK_CODES=AAPL,TSLA,600519.SS

# 邮件路由：邮箱:股票列表;邮箱:股票列表
EMAIL_STOCK_ROUTER=a@example.com:AAPL,TSLA;b@example.com:MSFT

# 发送邮箱配置（用于发送分组分析邮件）
SENDER_EMAIL=your_sender@example.com
SENDER_AUTH_CODE=your_email_auth_code
SMTP_HOST=smtp.example.com
SMTP_PORT=465

# DuckDuckGo 搜索配置
DUCKDUCKGO_MAX_RESULTS=5
DUCKDUCKGO_REGION=cn-zh

# 行情源（auto/akshare/yahoo/eastmoney）
MARKET_DATA_PROVIDER=auto

# 检索阶段 VPN/代理配置（用于海外新闻与全球数据）
SEARCH_USE_VPN=false
# 建议在 CI Secret 中配置该订阅 URL
CLASH_SUBSCRIPTION_URL=
# 本机 Clash HTTP 代理地址
CLASH_PROXY_URL=http://127.0.0.1:7890
